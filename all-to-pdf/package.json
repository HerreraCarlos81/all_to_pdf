{
  "name": "all-to-pdf",
  "publisher": "CodedNeurons",
  "displayName": "Project to PDF - AI Facilitator",
  "description": "Compile your entire project folder into a single PDF with line numbers, table of contents, directory tree, .gitignore support, and AI-friendly formatting.",
  "version": "0.0.3",
  "engines": {
    "vscode": "^1.88.0"
  },
  "icon": "images/all_to_pdf_logo.png",
  "galleryBanner": {
    "color": "#ffffff",
    "theme": "light"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "extension.convertProjectToPDF",
        "title": "Compile Folder to PDF"
      },
      {
        "command": "extension.convertProjectToPDFContext",
        "title": "Compile Folder to PDF"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "extension.convertProjectToPDFContext",
          "group": "yourGroup@1",
          "when": "explorerResourceIsFolder"
        }
      ]
    },
    "configuration": {
      "title": "All to PDF",
      "properties": {
        "allToPdf.useGitIgnore": {
          "type": "boolean",
          "default": true,
          "description": "Respect .gitignore rules when collecting files"
        },
        "allToPdf.exclude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional directory or file names to exclude (e.g. 'my-secrets')"
        },
        "allToPdf.maxFileSizeKb": {
          "type": "number",
          "default": 1024,
          "description": "Maximum file size in KB to include in the PDF (0 for no limit)"
        }
      }
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "node ./node_modules/mocha/bin/mocha ./test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^18.19.31",
    "@types/vscode": "^1.88.0",
    "@vscode/test-cli": "^0.0.8",
    "@vscode/test-electron": "^2.3.9",
    "eslint": "^8.57.0",
    "mocha": "^10.4.0",
    "typescript": "^5.4.5",
    "vsce": "^2.15.0",
    "vscode": "^1.1.37"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "fs-extra": "^11.2.0",
    "ignore": "^7.0.5",
    "jszip": "^3.10.1",
    "pdf-lib": "^1.17.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/HerreraCarlos81/all_to_pdf"
  }
}
